    /*

          Faça um programa baseado no conceito de pilhas para somar dois números.

    */
    
#include <stdio.h>
#include <stdlib.h>

typedef struct no{
    int valor;
    struct no *prox;
}No;

typedef struct pilha{
    No *topo;
}Pilha;

void criarPilha(Pilha *p){
    p->topo = NULL;
}

void empilhar(Pilha *p, int valor){

    No *novo = (No*)malloc(sizeof(No));

    if(novo == NULL){
        printf("Erro ao alocar memoria!\n");
        return;
    }

    novo->valor = valor;
    novo->prox = p->topo;
    p->topo = novo;
    
}

int desempilhar(Pilha *p){

    if(p->topo == NULL){
        printf("pilha vazia!\n");
        return 0;
    }

    No *remover = p->topo;
    int valorRemovido = remover->valor;
    p->topo = remover->prox;
    free(remover);

    return valorRemovido;
}

void imprimirPilha(Pilha *p){

    if(p->topo == NULL){
        printf("pilha vazia!\n");
        return;
    }

    No *aux = p->topo;

    printf("\n------ Pilha ------\n");

    while(aux != NULL){
        printf("\t%d\n", aux->valor);
        aux = aux->prox;
    }

    printf("---- Fim pilha ----\n");
    
}

void somarPilhas(Pilha *p1, Pilha *p2, Pilha *resultado){

    if(p1->topo == NULL || p2->topo == NULL){
        printf("Uma das pilhas esta vazia!\n");
        return;
    }

    int decimal = 0;

    while(p1->topo != NULL || p2->topo != NULL || decimal != 0){

        int v1 = desempilhar(p1);
        int v2 = desempilhar(p2);
        
        int soma = v1 + v2 + decimal;

        int resto = soma % 10;

        decimal = soma / 10;

        empilhar(resultado, resto);
    }
}

int main(){

    No *remover;

    Pilha pilha1, pilha2, resultado;

    criarPilha(&pilha1);
    criarPilha(&pilha2);
    criarPilha(&resultado);

    int op, valor;

    do{

        printf("1 - empilhar (pilha 1)\n");
        printf("2 - empilhar(pilha 2)\n");
        printf("3 - desempilhar(pilha 1)\n"); 
        printf("4 - desempilhar(pilha 2)\n");
        printf("5 - somar pilhas\n");
        printf("6 - imprimir pilha1\n");
        printf("7 - imprimir pilha2\n");
        printf("8 - imprimir resultado\n");
        printf("9 - sair\n");

        printf("Informe a opcao: ");
        scanf("%d",&op);

        switch(op){

            case 1:

                printf("Informe o valor a ser empilhado: ");
                scanf("%d", &valor);

                empilhar(&pilha1, valor);

                break;

            case 2:

                printf("Informe o valor a ser empilhado: ");
                scanf("%d", &valor);

                empilhar(&pilha2, valor);

                break;

            case 3:

                valor = desempilhar(&pilha1);

                if(valor != 0){
                    printf("Valor desempilhado: %d\n", valor);
                }else{
                    printf("Pilha 1 esta vazia!\n");
                }

                break;

            case 4:

                valor = desempilhar(&pilha2);

                if(valor != 0){
                    printf("Valor desempilhado: %d\n", valor);
                }else{
                    printf("Pilha 2 esta vazia!\n");
                }

                break;

            case 5:

                somarPilhas(&pilha1, &pilha2, &resultado);

                break;

            case 6:

                imprimirPilha(&pilha1);

                break;

            case 7:

                imprimirPilha(&pilha2);

                break;

            case 8:

                imprimirPilha(&resultado);

                break;

            case 9:

                printf("Saindo...\n");

                break;

            default:

                printf("Opcao invalida!\n");
        }

    }while(op != 9);

    return 0;
}
